local function getActiveThreatPositions()
    local threatPositions = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local isThreat = false
            
            if localRole == "Murderer" then
                if player.Character:FindFirstChild("Gun") or player.Backpack:FindFirstChild("Gun") then
                    isThreat = true
                end
            else
                if player.Character:FindFirstChild("Knife") or player.Backpack:FindFirstChild("Knife") then
                    isThreat = true
                end
            end
            
            if isThreat then
                table.insert(threatPositions, player.Character.HumanoidRootPart.Position)
            end
        end
    end
    return threatPositions
end

local function getClosestCoin(hrp, threatPositions)
    local coins = CollectionService:GetTagged("CoinVisual")
    local closestCoin = nil
    local shortestDistance = math.huge
    
    for _, coin in pairs(coins) do
        if coin and coin:IsA("BasePart") and coin.Parent and not coin:GetAttribute("Collected") and not coin:GetAttribute("Delete") then
            local isSafe = true
            for _, threatPos in pairs(threatPositions) do
                if (threatPos - coin.Position).Magnitude < safeRadius then
                    isSafe = false
                    break
                end
            end
            
            if isSafe then
                local distance = (hrp.Position - coin.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestCoin = coin
                end
            end
        end
    end
    
    if not closestCoin then
        shortestDistance = math.huge
        for _, coin in pairs(coins) do
            if coin and coin:IsA("BasePart") and coin.Parent and not coin:GetAttribute("Collected") and not coin:GetAttribute("Delete") then
                local distance = (hrp.Position - coin.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestCoin = coin
                end
            end
        end
    end
    
    return closestCoin
end

local function teleportToCoin(coin, hrp)
    local coinPosition = coin.CFrame.Position + Vector3.new(0, -5.0, 0)
    
    while enabled and gameActive and coin.Parent and not coin:GetAttribute("Collected") and not coin:GetAttribute("Delete") and localPlayer:GetAttribute("Alive") == true do
        local dt = RunService.Heartbeat:Wait()
        
        if not hrp or not hrp.Parent then break end
        
        local currentPos = hrp.Position
        local distance = (coinPosition - currentPos).Magnitude
        
        if distance <= 6 and firetouchinterest then
            fireCoinTouch(coin, hrp)
        end
        
        if distance <= 1.5 then 
            hrp.CFrame = CFrame.new(coinPosition)
            break
        end
        
        local direction = (coinPosition - currentPos).Unit
        hrp.CFrame = hrp.CFrame + (direction * (tweenSpeed * dt))
    end
end

local function isBagFull()
    local playerGui = localPlayer:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return false end
    
    for _, desc in pairs(playerGui:GetDescendants()) do
        if (desc.Name == "FullBagIcon" or desc.Name == "Full") and desc:IsA("GuiObject") then
            if desc.Visible and desc.Parent and desc.Parent.Visible then
                return true
            end
        end
    end
    
    return false
end

