local function fireCoinTouch(coinVisual, hrp)
    if not coinVisual or not coinVisual:IsA("BasePart") then
        return false
    end
    if not hrp or not hrp:IsA("BasePart") then
        return false
    end
    if not firetouchinterest then
        return false
    end
    local targetPart = nil
    if coinVisual.Parent then
        local serverPart = coinVisual.Parent:FindFirstChild("Coin_Server")
        if serverPart and serverPart:FindFirstChildOfClass("TouchTransmitter") then
            targetPart = serverPart
        else
            for _, desc in pairs(workspace:GetDescendants()) do
                if desc.Name == "Coin_Server" and desc:IsA("BasePart") and desc:FindFirstChildOfClass("TouchTransmitter") then
                    if (desc.Position - coinVisual.Position).Magnitude < 3 then
                        targetPart = desc
                        break
                    end
                end
            end
        end
    end
    if targetPart then
        firetouchinterest(hrp, targetPart, 0)
        firetouchinterest(hrp, targetPart, 1)
    else
        firetouchinterest(hrp, coinVisual, 0)
        firetouchinterest(hrp, coinVisual, 1)
    end
    return true
end

